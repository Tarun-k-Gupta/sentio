{
  "name": "knapp",
  "version": "1.0.0",
  "description": "Blockchain-powered random video chat with Stellar/Soroban reputation",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npx vite --host",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7"
  }
}
